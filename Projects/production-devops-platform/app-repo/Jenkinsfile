pipeline {
    agent any
    
    environment {
        AWS_REGION = 'us-east-1'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECR_REPOSITORY = 'devops-platform-app'
        IMAGE_TAG = "${env.GIT_COMMIT.take(7)}-${env.BUILD_NUMBER}"
        SONARQUBE_SERVER = 'SonarQube'
        GITOPS_REPO = 'git@github.com:your-org/gitops-repo.git'
        GITOPS_BRANCH = 'main'
    }
    
    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Target environment')
        booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: 'Skip tests')
        booleanParam(name: 'DEPLOY', defaultValue: true, description: 'Deploy to environment')
    }
    
    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Checking out code from branch: ${env.GIT_BRANCH}"
                    checkout scm
                }
            }
        }
        
        stage('Install Dependencies') {
            steps {
                script {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install --upgrade pip
                        pip install -r requirements.txt
                    '''
                }
            }
        }
        
        stage('Unit Tests') {
            when {
                expression { !params.SKIP_TESTS }
            }
            steps {
                script {
                    sh '''
                        . venv/bin/activate
                        pytest tests/ -v --cov=src --cov-report=xml --cov-report=html --junitxml=test-results.xml
                    '''
                }
            }
            post {
                always {
                    junit 'test-results.xml'
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'htmlcov',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ])
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                script {
                    withSonarQubeEnv("${SONARQUBE_SERVER}") {
                        sh '''
                            sonar-scanner \
                                -Dsonar.projectKey=devops-platform \
                                -Dsonar.sources=src \
                                -Dsonar.tests=tests \
                                -Dsonar.python.coverage.reportPaths=coverage.xml \
                                -Dsonar.python.xunit.reportPath=test-results.xml
                        '''
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to quality gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }
        
        stage('Security Scan') {
            steps {
                script {
                    sh '''
                        docker run --rm -v $(pwd):/app aquasec/trivy fs --severity HIGH,CRITICAL /app
                    '''
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    sh """
                        docker build -t ${ECR_REPOSITORY}:${IMAGE_TAG} .
                        docker tag ${ECR_REPOSITORY}:${IMAGE_TAG} ${ECR_REPOSITORY}:latest
                    """
                }
            }
        }
        
        stage('Push to ECR') {
            steps {
                script {
                    sh """
                        aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                        docker tag ${ECR_REPOSITORY}:${IMAGE_TAG} ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
                        docker tag ${ECR_REPOSITORY}:${IMAGE_TAG} ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest
                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest
                    """
                }
            }
        }
        
        stage('Update GitOps Repo') {
            when {
                expression { params.DEPLOY }
            }
            steps {
                script {
                    withCredentials([sshUserPrivateKey(credentialsId: 'github-ssh-key', keyFileVariable: 'SSH_KEY')]) {
                        sh """
                            # Configure Git
                            git config --global user.email "jenkins@example.com"
                            git config --global user.name "Jenkins CI"
                            
                            # Setup SSH
                            mkdir -p ~/.ssh
                            cp \${SSH_KEY} ~/.ssh/id_rsa
                            chmod 600 ~/.ssh/id_rsa
                            ssh-keyscan github.com >> ~/.ssh/known_hosts
                            
                            # Clone GitOps repo
                            rm -rf gitops-repo
                            git clone ${GITOPS_REPO} gitops-repo
                            cd gitops-repo
                            
                            # Update image tag
                            sed -i 's|image: .*|image: ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}|g' apps/${params.ENVIRONMENT}/deployment.yaml
                            
                            # Commit and push
                            git add apps/${params.ENVIRONMENT}/deployment.yaml
                            git commit -m "Update ${params.ENVIRONMENT} image to ${IMAGE_TAG} [skip ci]" || true
                            git push origin ${GITOPS_BRANCH}
                        """
                    }
                }
            }
        }
        
        stage('Approval for Production') {
            when {
                expression { params.ENVIRONMENT == 'prod' }
            }
            steps {
                script {
                    input message: 'Deploy to Production?', ok: 'Deploy', submitter: 'admin'
                }
            }
        }
        
        stage('Trigger ArgoCD Sync') {
            when {
                expression { params.DEPLOY }
            }
            steps {
                script {
                    sh """
                        argocd app sync devops-platform-${params.ENVIRONMENT} --grpc-web || echo "ArgoCD will auto-sync"
                    """
                }
            }
        }
        
        stage('Verify Deployment') {
            when {
                expression { params.DEPLOY }
            }
            steps {
                script {
                    sh """
                        sleep 30
                        kubectl get pods -n ${params.ENVIRONMENT} -l app=devops-platform
                        kubectl rollout status deployment/devops-platform -n ${params.ENVIRONMENT} --timeout=5m
                    """
                }
            }
        }
    }
    
    post {
        success {
            echo "Pipeline completed successfully!"
            script {
                // Send notification
                sh """
                    aws sns publish \
                        --topic-arn arn:aws:sns:${AWS_REGION}:${AWS_ACCOUNT_ID}:jenkins-notifications \
                        --message "Build ${BUILD_NUMBER} succeeded for ${params.ENVIRONMENT}" \
                        --subject "Jenkins Build Success"
                """
            }
        }
        failure {
            echo "Pipeline failed!"
            script {
                sh """
                    aws sns publish \
                        --topic-arn arn:aws:sns:${AWS_REGION}:${AWS_ACCOUNT_ID}:jenkins-notifications \
                        --message "Build ${BUILD_NUMBER} failed for ${params.ENVIRONMENT}" \
                        --subject "Jenkins Build Failure"
                """
            }
        }
        always {
            cleanWs()
        }
    }
}
